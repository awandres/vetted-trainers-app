{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && corepack enable && pnpm install",
  "buildCommand": "cd ../.. && pnpm turbo build --filter=@vt/admin",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/marketing/cron",
      "schedule": "*/5 * * * *"
    }
  ]
}
